generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AuditStatus {
  SUCCESS
  FAILURE
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum AcademicYearStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum AcademicTermType {
  SEMESTER
  TRIMESTER
  QUARTER
  CUSTOM
}

enum GradeStage {
  PRE_SCHOOL
  PRIMARY
  MIDDLE
  HIGH
  OTHER
}

enum SubjectCategory {
  CORE
  ELECTIVE
  LANGUAGE
  SCIENCE
  MATHEMATICS
  HUMANITIES
  ARTS
  SPORTS
  TECHNOLOGY
  OTHER
}

model User {
  id           String    @id @default(cuid()) @db.VarChar(191)
  email        String    @unique @db.VarChar(191)
  username     String?   @unique @db.VarChar(64)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(120)
  lastName     String    @map("last_name") @db.VarChar(120)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdById  String?   @map("created_by") @db.VarChar(191)
  updatedById  String?   @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("user_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("user_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  createdUsers User[] @relation("user_created_by")
  updatedUsers User[] @relation("user_updated_by")

  userRoles              UserRole[]
  auditLogsAsActor       AuditLog[]       @relation("audit_actor")
  auditLogsCreated       AuditLog[]       @relation("audit_created_by")
  auditLogsUpdated       AuditLog[]       @relation("audit_updated_by")
  rolesCreated           Role[]           @relation("role_created_by")
  rolesUpdated           Role[]           @relation("role_updated_by")
  permissionsCreated     Permission[]     @relation("permission_created_by")
  permissionsUpdated     Permission[]     @relation("permission_updated_by")
  userRolesCreated       UserRole[]       @relation("user_role_created_by")
  userRolesUpdated       UserRole[]       @relation("user_role_updated_by")
  rolePermissionsCreated RolePermission[] @relation("role_permission_created_by")
  rolePermissionsUpdated RolePermission[] @relation("role_permission_updated_by")
  settingsCreated        GlobalSetting[]  @relation("setting_created_by")
  settingsUpdated        GlobalSetting[]  @relation("setting_updated_by")
  academicYearsCreated   AcademicYear[]   @relation("academic_year_created_by")
  academicYearsUpdated   AcademicYear[]   @relation("academic_year_updated_by")
  academicTermsCreated   AcademicTerm[]   @relation("academic_term_created_by")
  academicTermsUpdated   AcademicTerm[]   @relation("academic_term_updated_by")
  gradeLevelsCreated     GradeLevel[]     @relation("grade_level_created_by")
  gradeLevelsUpdated     GradeLevel[]     @relation("grade_level_updated_by")
  sectionsCreated        Section[]        @relation("section_created_by")
  sectionsUpdated        Section[]        @relation("section_updated_by")
  subjectsCreated        Subject[]        @relation("subject_created_by")
  subjectsUpdated        Subject[]        @relation("subject_updated_by")

  @@index([deletedAt])
  @@index([isActive, deletedAt])
  @@map("users")
}

model Role {
  id          String    @id @default(cuid()) @db.VarChar(191)
  code        String    @unique @db.VarChar(120)
  name        String    @db.VarChar(120)
  description String?   @db.VarChar(255)
  isSystem    Boolean   @default(false) @map("is_system")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by") @db.VarChar(191)
  updatedById String?   @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("role_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("role_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([deletedAt])
  @@index([isActive, deletedAt])
  @@map("roles")
}

model Permission {
  id          String    @id @default(cuid()) @db.VarChar(191)
  code        String    @unique @db.VarChar(120)
  resource    String    @db.VarChar(120)
  action      String    @db.VarChar(120)
  description String?   @db.VarChar(255)
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by") @db.VarChar(191)
  updatedById String?   @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("permission_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("permission_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  rolePermissions RolePermission[]

  @@index([deletedAt])
  @@index([resource, action])
  @@map("permissions")
}

model UserRole {
  id          String    @id @default(cuid()) @db.VarChar(191)
  userId      String    @map("user_id") @db.VarChar(191)
  roleId      String    @map("role_id") @db.VarChar(191)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by") @db.VarChar(191)
  updatedById String?   @map("updated_by") @db.VarChar(191)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  createdBy User? @relation("user_role_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("user_role_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([roleId, deletedAt])
  @@index([deletedAt])
  @@map("user_roles")
}

model RolePermission {
  id           String    @id @default(cuid()) @db.VarChar(191)
  roleId       String    @map("role_id") @db.VarChar(191)
  permissionId String    @map("permission_id") @db.VarChar(191)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdById  String?   @map("created_by") @db.VarChar(191)
  updatedById  String?   @map("updated_by") @db.VarChar(191)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  createdBy User? @relation("role_permission_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("role_permission_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([roleId, permissionId])
  @@index([permissionId, deletedAt])
  @@index([deletedAt])
  @@map("role_permissions")
}

model AuditLog {
  id          String      @id @default(cuid()) @db.VarChar(191)
  actorUserId String?     @map("actor_user_id") @db.VarChar(191)
  action      String      @db.VarChar(120)
  resource    String      @db.VarChar(120)
  resourceId  String?     @map("resource_id") @db.VarChar(191)
  status      AuditStatus @default(SUCCESS)
  ipAddress   String?     @map("ip_address") @db.VarChar(64)
  userAgent   String?     @map("user_agent") @db.VarChar(255)
  details     Json?
  occurredAt  DateTime    @default(now()) @map("occurred_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")
  createdById String?     @map("created_by") @db.VarChar(191)
  updatedById String?     @map("updated_by") @db.VarChar(191)

  actorUser User? @relation("audit_actor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdBy User? @relation("audit_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("audit_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([resource, resourceId])
  @@index([actorUserId, occurredAt])
  @@index([deletedAt])
  @@map("audit_logs")
}

model GlobalSetting {
  id          String           @id @default(cuid()) @db.VarChar(191)
  key         String           @unique @db.VarChar(120)
  value       Json
  valueType   SettingValueType @default(JSON) @map("value_type")
  description String?          @db.VarChar(255)
  isPublic    Boolean          @default(false) @map("is_public")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  createdById String?          @map("created_by") @db.VarChar(191)
  updatedById String?          @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("setting_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("setting_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([deletedAt])
  @@map("global_settings")
}

model AcademicYear {
  id          String             @id @default(cuid()) @db.VarChar(191)
  code        String             @unique @db.VarChar(40)
  name        String             @db.VarChar(120)
  startDate   DateTime           @map("start_date")
  endDate     DateTime           @map("end_date")
  status      AcademicYearStatus @default(PLANNED)
  isCurrent   Boolean            @default(false) @map("is_current")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")
  createdById String?            @map("created_by") @db.VarChar(191)
  updatedById String?            @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("academic_year_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("academic_year_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  terms AcademicTerm[]

  @@index([status, deletedAt])
  @@index([isCurrent, deletedAt])
  @@index([deletedAt])
  @@map("academic_years")
}

model AcademicTerm {
  id             String           @id @default(cuid()) @db.VarChar(191)
  academicYearId String           @map("academic_year_id") @db.VarChar(191)
  code           String           @db.VarChar(40)
  name           String           @db.VarChar(120)
  termType       AcademicTermType @default(SEMESTER) @map("term_type")
  sequence       Int
  startDate      DateTime         @map("start_date")
  endDate        DateTime         @map("end_date")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")
  createdById    String?          @map("created_by") @db.VarChar(191)
  updatedById    String?          @map("updated_by") @db.VarChar(191)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  createdBy User? @relation("academic_term_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("academic_term_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([academicYearId, code])
  @@unique([academicYearId, sequence])
  @@index([academicYearId, deletedAt])
  @@index([isActive, deletedAt])
  @@index([deletedAt])
  @@map("academic_terms")
}

model GradeLevel {
  id          String     @id @default(cuid()) @db.VarChar(191)
  code        String     @unique @db.VarChar(40)
  name        String     @db.VarChar(120)
  stage       GradeStage @default(OTHER)
  sequence    Int
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")
  createdById String?    @map("created_by") @db.VarChar(191)
  updatedById String?    @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("grade_level_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("grade_level_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  sections Section[]

  @@unique([stage, sequence])
  @@index([isActive, deletedAt])
  @@index([deletedAt])
  @@map("grade_levels")
}

model Section {
  id           String    @id @default(cuid()) @db.VarChar(191)
  gradeLevelId String    @map("grade_level_id") @db.VarChar(191)
  code         String    @db.VarChar(40)
  name         String    @db.VarChar(120)
  capacity     Int?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdById  String?   @map("created_by") @db.VarChar(191)
  updatedById  String?   @map("updated_by") @db.VarChar(191)

  gradeLevel GradeLevel @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)

  createdBy User? @relation("section_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("section_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([gradeLevelId, code])
  @@index([gradeLevelId, deletedAt])
  @@index([isActive, deletedAt])
  @@index([deletedAt])
  @@map("sections")
}

model Subject {
  id          String          @id @default(cuid()) @db.VarChar(191)
  code        String          @unique @db.VarChar(40)
  name        String          @db.VarChar(120)
  shortName   String?         @map("short_name") @db.VarChar(50)
  category    SubjectCategory @default(OTHER)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")
  createdById String?         @map("created_by") @db.VarChar(191)
  updatedById String?         @map("updated_by") @db.VarChar(191)

  createdBy User? @relation("subject_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("subject_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([category, deletedAt])
  @@index([isActive, deletedAt])
  @@index([deletedAt])
  @@map("subjects")
}
